# Copy this file to .env and fill in your real values.
# The .env file is gitignored — never commit real secrets.

# Which LLM provider the app uses (must match a key in app/ai/llm.py's registry).
# Change this one line to switch providers app-wide. Default: groq.
LLM_PROVIDER=groq

# Optional: pin a specific model id. Leave blank to use the factory's default
# model for the selected provider.
LLM_MODEL=

# API key for the active provider. Only the one matching LLM_PROVIDER is required.
# Groq (default) — get a free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Anthropic — get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
